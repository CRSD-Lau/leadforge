# ── Anthropic (required) ──────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend — outbound email (required) ───────────────────────────────────────
# Sign up free at: https://resend.com/
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_...

# ── Google Maps Places API (required) ────────────────────────────────────────
# Enable "Places API" at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=AIza...

# ── Sender identity (optional — defaults shown) ───────────────────────────────
SENDER_EMAIL=neil@leadforge-ai.ca

# ── Gmail reply reading (optional — needed for reply handling) ───────────────
# Follow: https://developers.google.com/gmail/api/quickstart/python
# Download credentials.json from Google Cloud Console → OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# ── Storage paths (optional — defaults shown) ─────────────────────────────────
DB_PATH=leads.db
MOCKUPS_DIR=mockups
